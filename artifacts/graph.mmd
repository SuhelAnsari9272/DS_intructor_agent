---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	router(router)
	python(python)
	sql(sql)
	excel(excel)
	ml(ml)
	__end__([<p>__end__</p>]):::last
	__start__ --> router;
	router -.-> excel;
	router -.-> ml;
	router -.-> python;
	router -.-> sql;
	excel --> __end__;
	ml --> __end__;
	python --> __end__;
	sql --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
